generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum SituacaoMilitar {
  ATIVO
  AFASTADO
  TRANSFERIDO
  RESERVA
}

enum TipoRefeicao {
  CAFE
  ALMOCO
  JANTA
  CEIA
}

enum StatusPeriodoArranchamento {
  ABERTO
  FECHADO
}

enum CodigoPerfil {
  MILITAR
  FURRIEL
  APROVISIONAMENTO
  SARGENTEANTE
  ADMINISTRADOR
}

model Subunidade {
  id        Int      @id @default(autoincrement())
  sigla     String   @unique @db.VarChar(20)
  nome      String   @db.VarChar(120)
  ativa     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  militares      Militar[]
  arranchamentos Arranchamento[]
  escalasServico EscalaServico[]
  consolidados   ConsolidadoRefeicao[]

  @@map("subunidades")
}

model Militar {
  id                Int             @id @default(autoincrement())
  identidadeMilitar String          @unique @map("identidade_militar") @db.VarChar(30)
  nomeCompleto      String          @map("nome_completo") @db.VarChar(160)
  nomeGuerra        String          @map("nome_guerra") @db.VarChar(80)
  postoGraduacao    String          @map("posto_graduacao") @db.VarChar(50)
  situacao          SituacaoMilitar @default(ATIVO)
  subunidadeId      Int             @map("subunidade_id")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  subunidade Subunidade @relation(fields: [subunidadeId], references: [id])
  usuario    Usuario?

  ferias         FeriasMilitar[]
  arranchamentos Arranchamento[]
  escalasServico EscalaServico[]

  @@index([subunidadeId])
  @@map("militares")
}

model Usuario {
  id             Int       @id @default(autoincrement())
  militarId      Int       @unique @map("militar_id")
  email          String?   @unique @db.VarChar(160)
  senhaHash      String    @map("senha_hash") @db.VarChar(255)
  ativo          Boolean   @default(true)
  primeiroAcesso Boolean   @default(true) @map("primeiro_acesso")
  ultimoLogin    DateTime? @map("ultimo_login")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  militar Militar         @relation(fields: [militarId], references: [id])
  perfis  UsuarioPerfil[]
  sessoes Sessao[]

  periodosAbertos            PeriodoArranchamento[] @relation("PeriodoAbertoPor")
  periodosFechados           PeriodoArranchamento[] @relation("PeriodoFechadoPor")
  feriasCadastradas          FeriasMilitar[]        @relation("FeriasCadastradasPor")
  escalasCadastradas         EscalaServico[]        @relation("EscalaCadastradaPor")
  feriadosCadastrados        Feriado[]              @relation("FeriadoCadastradoPor")
  configuracoesOmAtualizadas ConfiguracaoOm[]       @relation("ConfiguracaoOmAtualizadaPor")
  auditorias                 Auditoria[]

  @@map("usuarios")
}

model Perfil {
  id        Int          @id @default(autoincrement())
  codigo    CodigoPerfil @unique
  nome      String       @db.VarChar(80)
  descricao String?      @db.VarChar(255)

  usuarios   UsuarioPerfil[]
  permissoes PerfilPermissao[]

  @@map("perfis")
}

model Permissao {
  id        Int     @id @default(autoincrement())
  codigo    String  @unique @db.VarChar(100)
  descricao String? @db.VarChar(255)

  perfis PerfilPermissao[]

  @@map("permissoes")
}

model UsuarioPerfil {
  usuarioId Int @map("usuario_id")
  perfilId  Int @map("perfil_id")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  perfil  Perfil  @relation(fields: [perfilId], references: [id], onDelete: Cascade)

  @@id([usuarioId, perfilId])
  @@map("usuario_perfis")
}

model PerfilPermissao {
  perfilId    Int @map("perfil_id")
  permissaoId Int @map("permissao_id")

  perfil    Perfil    @relation(fields: [perfilId], references: [id], onDelete: Cascade)
  permissao Permissao @relation(fields: [permissaoId], references: [id], onDelete: Cascade)

  @@id([perfilId, permissaoId])
  @@map("perfil_permissoes")
}

model Sessao {
  id               Int       @id @default(autoincrement())
  usuarioId        Int       @map("usuario_id")
  refreshTokenHash String    @unique @map("refresh_token_hash") @db.Char(64)
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  ip               String?   @db.VarChar(45)
  userAgent        String?   @map("user_agent") @db.VarChar(500)
  createdAt        DateTime  @default(now()) @map("created_at")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([expiresAt])
  @@map("sessoes")
}

model PeriodoArranchamento {
  id           Int                        @id @default(autoincrement())
  dataInicio   DateTime                   @unique @map("data_inicio") @db.Date
  dataFim      DateTime                   @unique @map("data_fim") @db.Date
  status       StatusPeriodoArranchamento @default(ABERTO)
  abertoPorId  Int                        @map("aberto_por_id")
  fechadoPorId Int?                       @map("fechado_por_id")
  abertoEm     DateTime                   @default(now()) @map("aberto_em")
  fechadoEm    DateTime?                  @map("fechado_em")

  abertoPor  Usuario  @relation("PeriodoAbertoPor", fields: [abertoPorId], references: [id])
  fechadoPor Usuario? @relation("PeriodoFechadoPor", fields: [fechadoPorId], references: [id])

  arranchamentos Arranchamento[]
  escalasServico EscalaServico[]
  consolidados   ConsolidadoRefeicao[]

  @@index([status])
  @@map("periodos_arranchamento")
}

model Arranchamento {
  id           Int          @id @default(autoincrement())
  periodoId    Int          @map("periodo_id")
  militarId    Int          @map("militar_id")
  subunidadeId Int          @map("subunidade_id")
  data         DateTime     @db.Date
  refeicao     TipoRefeicao
  createdAt    DateTime     @default(now()) @map("created_at")

  periodo    PeriodoArranchamento @relation(fields: [periodoId], references: [id])
  militar    Militar              @relation(fields: [militarId], references: [id])
  subunidade Subunidade           @relation(fields: [subunidadeId], references: [id])

  @@unique([militarId, data, refeicao])
  @@index([periodoId, data, refeicao])
  @@index([subunidadeId])
  @@map("arranchamentos")
}

model EscalaServico {
  id              Int      @id @default(autoincrement())
  periodoId       Int      @map("periodo_id")
  militarId       Int      @map("militar_id")
  subunidadeId    Int      @map("subunidade_id")
  data            DateTime @db.Date
  cadastradoPorId Int      @map("cadastrado_por_id")
  createdAt       DateTime @default(now()) @map("created_at")

  periodo       PeriodoArranchamento @relation(fields: [periodoId], references: [id])
  militar       Militar              @relation(fields: [militarId], references: [id])
  subunidade    Subunidade           @relation(fields: [subunidadeId], references: [id])
  cadastradoPor Usuario              @relation("EscalaCadastradaPor", fields: [cadastradoPorId], references: [id])

  @@unique([militarId, data])
  @@index([periodoId, data])
  @@index([subunidadeId])
  @@map("escalas_servico")
}

model FeriasMilitar {
  id              Int      @id @default(autoincrement())
  militarId       Int      @map("militar_id")
  dataInicio      DateTime @map("data_inicio") @db.Date
  dataFim         DateTime @map("data_fim") @db.Date
  laranjeira      Boolean  @default(false)
  cadastradoPorId Int      @map("cadastrado_por_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  militar       Militar @relation(fields: [militarId], references: [id])
  cadastradoPor Usuario @relation("FeriasCadastradasPor", fields: [cadastradoPorId], references: [id])

  @@index([militarId, dataInicio, dataFim])
  @@map("ferias_militares")
}

model Feriado {
  id              Int      @id @default(autoincrement())
  data            DateTime @unique @db.Date
  descricao       String   @db.VarChar(120)
  cadastradoPorId Int      @map("cadastrado_por_id")
  createdAt       DateTime @default(now()) @map("created_at")

  cadastradoPor Usuario @relation("FeriadoCadastradoPor", fields: [cadastradoPorId], references: [id])

  @@map("feriados")
}

model ConsolidadoRefeicao {
  id                   Int          @id @default(autoincrement())
  periodoId            Int          @map("periodo_id")
  subunidadeId         Int          @map("subunidade_id")
  data                 DateTime     @db.Date
  refeicao             TipoRefeicao
  quantidade           Int
  quantidadeIndividual Int          @map("quantidade_individual")
  quantidadeGu         Int          @map("quantidade_gu")
  createdAt            DateTime     @default(now()) @map("created_at")

  periodo    PeriodoArranchamento @relation(fields: [periodoId], references: [id])
  subunidade Subunidade           @relation(fields: [subunidadeId], references: [id])

  @@unique([periodoId, subunidadeId, data, refeicao])
  @@index([periodoId, data, refeicao])
  @@index([subunidadeId])
  @@map("consolidados_refeicoes")
}

model ConfiguracaoOm {
  id              Int      @id
  nome            String   @db.VarChar(160)
  sigla           String   @db.VarChar(30)
  postoComandante String   @map("posto_comandante") @db.VarChar(50)
  nomeComandante  String   @map("nome_comandante") @db.VarChar(160)
  atualizadoPorId Int      @map("atualizado_por_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  atualizadoPor Usuario @relation("ConfiguracaoOmAtualizadaPor", fields: [atualizadoPorId], references: [id])

  @@map("configuracao_om")
}

model Auditoria {
  id         Int      @id @default(autoincrement())
  usuarioId  Int?     @map("usuario_id")
  acao       String   @db.VarChar(20)
  recurso    String   @db.VarChar(80)
  recursoId  String?  @map("recurso_id") @db.VarChar(80)
  metodo     String   @db.VarChar(10)
  rota       String   @db.VarChar(255)
  statusHttp Int      @map("status_http")
  dados      Json?
  ip         String?  @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at")

  usuario Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([usuarioId, createdAt])
  @@index([recurso, createdAt])
  @@map("auditorias")
}
